{
  "version": 2,
  "installCommand": "g++ -O2 -o game/engine/main game/engine/main.cpp && chmod +x game/engine/main",
  "builds": [
    {
      "src": "core/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "includeFiles": "game/engine/main"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "core/wsgi.py"
    }
  ]
}
